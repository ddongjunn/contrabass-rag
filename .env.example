# 환경변수 템플릿 — 이 파일을 복사해 `.env`를 만들고 실제 값을 채우세요.
# --- OpenAI (Moderation도 동일 키 재사용) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Slack ---
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxx          # App-Level Token (Socket Mode)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxx            # Bot User OAuth Token

# --- Database (PostgreSQL + pgvector) ---
# docker compose: db 서비스가 POSTGRES_DB=contrabass_rag 로 생성됨.
#   아래 USER/PASSWORD가 db 컨테이너와 app 양쪽에 주입됩니다.
DB_USERNAME=postgres
DB_PASSWORD=changeme

# 로컬에서 앱만 직접 실행할 때(compose 미사용) Spring 표준 키로 접속 지정:
# SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/contrabass_rag
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=changeme

# --- Prometheus (RESOURCE METRIC 트랙) ---
PROMETHEUS_URL=https://10.255.x.x:xxxxx

# --- cb_common MySQL (RESOURCE INVENTORY 트랙) ---
# useSSL=false: 내부망 자체서명 인증서 우회
RESOURCE_INVENTORY_ENABLED=true
DP_COMMON_URL=jdbc:mysql://HOST:PORT/cb_common?useSSL=false&allowPublicKeyRetrieval=true
DP_COMMON_USER_NAME=
DP_COMMON_PASSWORD=
CB_PROVIDER_UUID=

# --- 챗봇 위젯 임베드용 CORS (app.cors.allowed-origins) ---
# 위젯을 임베드하는 포털의 origin을 콤마로 구분해 나열한다. /api/chat 과 위젯 스크립트
# (/chat-widget/**) 양쪽에 적용된다. 비우면 CORS 미적용이라 포털에서의 호출이 차단된다.
# 예) 로컬 포털에서 VM 백엔드를 붙일 때: http://localhost:18100
APP_CORS_ALLOWED_ORIGINS=
