# 환경변수 템플릿 — 이 파일을 복사해 `.env`를 만들고 실제 값을 채우세요.
# --- OpenAI (Moderation도 동일 키 재사용) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Slack ---
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxx          # App-Level Token (Socket Mode)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxx            # Bot User OAuth Token

# --- Database (PostgreSQL + pgvector) ---
# docker compose: db 서비스가 POSTGRES_DB=contrabass_rag 로 생성됨.
#   아래 USER/PASSWORD가 db 컨테이너와 app 양쪽에 주입됩니다.
DB_USERNAME=postgres
DB_PASSWORD=changeme

# 로컬에서 앱만 직접 실행할 때(compose 미사용) Spring 표준 키로 접속 지정:
# SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/contrabass_rag
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=changeme
