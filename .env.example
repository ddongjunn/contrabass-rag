# 환경변수 템플릿 — 이 파일을 복사해 `.env`를 만들고 실제 값을 채우세요.
#   cp .env.example .env
# .env 는 커밋하지 않습니다(.gitignore 포함).

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Slack ---
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxx          # App-Level Token (Socket Mode)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxx            # Bot User OAuth Token

# --- Database (PostgreSQL + pgvector) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=changeme
# SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
