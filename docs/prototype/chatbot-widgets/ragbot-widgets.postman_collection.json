{
  "info": {
    "name": "ragbot — 챗봇 위젯 (POST /api/chat)",
    "description": "POST /api/chat 위젯·히스토리 계약 검증 — target 8종(실존 메트릭 기반) + 히스토리 후속질문 4종. 레이트 리밋(userId별 분당 5회) 회피를 위해 요청마다 userId를 가른다. 2026-07-24 재작성.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "postman-runner",
      "type": "string",
      "description": "요청마다 -1, -2 … 접미사가 붙는다. 레이트 리밋(app.guard.rate-per-min, 기본 5)이 userId별이라 같은 값으로 8개를 쏘면 6번째부터 막힌다."
    },
    {
      "key": "runUserId",
      "value": "postman-runner-1",
      "type": "string",
      "description": "prerequest가 요청마다 채운다. 직접 건드리지 말 것."
    },
    {
      "key": "seq",
      "value": "0",
      "type": "string",
      "description": "내부 카운터."
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ⚠️ 레이트 리밋은 userId별 분당 5회다(app.guard.rate-per-min).",
          "//    같은 userId로 8개를 연속으로 쏘면 6번째부터 `chat rate-limited`로 막혀 LLM 근처도 못 간다",
          "//    (routingCalls=0). 실제로 겪어서 넣은 방어다 — 요청마다 userId를 갈라 리밋을 피한다.",
          "const seq = (pm.collectionVariables.get('seq') | 0) + 1;",
          "pm.collectionVariables.set('seq', seq);",
          "pm.collectionVariables.set('runUserId', `${pm.collectionVariables.get('userId')}-${seq}`);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 레이트 리밋에 걸리면 아래 계약 테스트가 엉뚱하게 실패한다 — 먼저 걸러서 원인을 알려준다.",
          "const looksRateLimited = pm.response.responseTime < 50 && pm.response.json().widgets.length === 0;",
          "pm.test('레이트 리밋에 안 걸렸다 (userId별 분당 5회)', () => {",
          "  pm.expect(looksRateLimited, '응답이 50ms 미만 + 위젯 0개 → rate-limited 의심. 앱 로그의 `chat rate-limited` 확인').to.be.false;",
          "});",
          "",
          "// ── 모든 응답이 지켜야 하는 계약 (widget-contract.d.ts §ChatResponse) ──",
          "pm.test('200 OK', () => pm.response.to.have.status(200));",
          "",
          "const body = pm.response.json();",
          "",
          "pm.test('answer는 항상 존재한다 (불변식: 위젯이 있어도 평문은 함께 나간다)', () => {",
          "  pm.expect(body.answer, 'answer').to.be.a('string').and.not.empty;",
          "});",
          "",
          "pm.test('sources/widgets/followups는 항상 배열 (하위호환: 없으면 [])', () => {",
          "  pm.expect(body.sources, 'sources').to.be.an('array');",
          "  pm.expect(body.widgets, 'widgets').to.be.an('array');",
          "  pm.expect(body.followups, 'followups').to.be.an('array');",
          "});",
          "",
          "pm.test('모든 위젯에 type 판별자가 있다 (Jackson EXISTING_PROPERTY)', () => {",
          "  const known = ['metric_rank', 'inventory_count', 'threshold_banner', 'status_donut', 'usage_bar', 'metric_line'];",
          "  body.widgets.forEach(w => {",
          "    pm.expect(w.type, 'widget.type').to.be.a('string');",
          "    pm.expect(known, `모르는 위젯 타입: ${w.type}`).to.include(w.type);",
          "  });",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. METRIC — CPU TopN → metric_rank",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "chat"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"cpu 사용량 높은 VM 5개 보여줘\",\n  \"userId\": \"{{runUserId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const w = pm.response.json().widgets.find(x => x.type === 'metric_rank');",
              "pm.test('metric_rank 위젯이 온다', () => pm.expect(w, 'metric_rank 없음 — 라우팅/추출이 다른 곳으로 샜을 수 있다').to.exist);",
              "if (!w) return;",
              "",
              "pm.test('근거 promql이 계약에 있다(화면 미표기, 검증용)', () => pm.expect(w.promql).to.be.a('string').and.not.empty);",
              "pm.test('행마다 display 포맷 완료', () => w.rows.forEach(r => pm.expect(r.display, `${r.instanceName}.display`).to.be.a('string').and.not.empty));",
              "pm.test('empty와 rows 일치', () => pm.expect(w.empty).to.eql(w.rows.length === 0));",
              "pm.test('5행', () => pm.expect(w.rows.length).to.eql(5));"
            ]
          }
        }
      ]
    },
