        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const w = pm.response.json().widgets.find(x => x.type === 'metric_line');",
              "pm.test('metric_line 위젯이 온다', () => pm.expect(w, 'metric_line 없음 — 라우팅/추출이 다른 곳으로 샜을 수 있다').to.exist);",
              "if (!w) return;",
              "",
              "pm.test('시리즈가 1개 이상, 포인트가 2개 이상(진짜 시계열)', () => {",
              "  pm.expect(w.series.length, 'series').to.be.above(0);",
              "  w.series.forEach(s => pm.expect(s.points.length, `${s.name}.points`).to.be.above(1));",
              "});",
              "pm.test('포인트는 {ts,value} 숫자쌍', () => {",
              "  const p = w.series[0].points[0];",
              "  pm.expect(p.ts).to.be.a('number'); pm.expect(p.value).to.be.a('number');",
              "});",
              "pm.test('시리즈 상한 5', () => pm.expect(w.series.length).to.be.at.most(5));"
            ]
          }
        }
      ]
